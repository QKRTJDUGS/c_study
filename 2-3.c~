#include <stdio.h>

void main()
{
	int a, b;
	int result;

	printf("첫 번 째 계산 할 값을 입력하세요 ==>");
	scanf("%d", &a);

	printf("두 번 째 계산 할 값을 입력하세요 ==>");
	scanf("%d", &b);

	result = a + b;
	printf(" %d + %d = %d \n", a, b, result);

	result = a - b;
	printf(" %d - %d = %d \n", a, b, result);

	result = a * b;
	printf(" %d * %d = %d \n", a, b, result);

	result = a / b;
	printf(" %d / %d = %d \n", a, b, result);
}
